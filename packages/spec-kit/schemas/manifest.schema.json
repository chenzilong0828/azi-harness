{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azi-harness.dev/schemas/manifest.schema.json",
  "title": "azi-harness runtime manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runtimeVersion",
    "generatedAt",
    "files",
    "detectionDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "runtimeVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "ownership",
          "templateVersion",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "ownership": {
            "enum": [
              "managed",
              "seeded",
              "user"
            ]
          },
          "templateVersion": {
            "type": [
              "string",
              "null"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "detectionDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}

