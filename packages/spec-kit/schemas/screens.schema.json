{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azi-harness.dev/schemas/screens.schema.json",
  "title": "azi-harness feature screens",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "feature",
    "source",
    "screens",
    "unknowns"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "feature": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "url",
        "nodeId",
        "reference",
        "status",
        "retriedAt",
        "fallback",
        "notes"
      ],
      "properties": {
        "type": {
          "enum": [
            "figma-mcp",
            "figma-export",
            "screenshot",
            "legacy-page",
            "none"
          ]
        },
        "url": {
          "type": "string"
        },
        "nodeId": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pending",
            "ok",
            "rate-limited",
            "fallback",
            "unavailable"
          ]
        },
        "retriedAt": {
          "type": "string"
        },
        "fallback": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/screen"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unknown"
      }
    }
  },
  "$defs": {
    "screen": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "route",
        "title",
        "states",
        "regions",
        "interactions",
        "assets"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "route": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "default",
              "loading",
              "empty",
              "error",
              "forbidden",
              "disabled"
            ]
          }
        },
        "regions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "interactions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "unknown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "question",
        "blocking"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean"
        }
      }
    }
  }
}
