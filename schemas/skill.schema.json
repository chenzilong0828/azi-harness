{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azi-harness.dev/schemas/skill.schema.json",
  "title": "AZI Skill",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "title",
    "description",
    "role",
    "instructions",
    "inputs",
    "outputs",
    "permissions",
    "approval",
    "completionCriteria",
    "stopConditions"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "role": {
      "enum": ["discovery", "product", "planning", "coding", "testing", "review", "delivery"]
    },
    "instructions": {
      "$ref": "#/$defs/relativePath"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "description"],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "reads": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactType", "required"],
        "properties": {
          "artifactType": {
            "$ref": "#/$defs/id"
          },
          "required": {
            "type": "boolean"
          },
          "pathTemplate": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filesystem", "commands", "git", "network", "externalSideEffects"],
      "properties": {
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "required": ["read", "write"],
          "properties": {
            "read": {
              "$ref": "#/$defs/globs"
            },
            "write": {
              "$ref": "#/$defs/globs"
            }
          }
        },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "enum": ["denied", "project-readonly", "project-allowlist", "approval-required"]
            },
            "allow": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "git": {
          "enum": ["denied", "read", "write-with-approval"]
        },
        "network": {
          "enum": ["denied", "read-with-approval", "write-with-approval"]
        },
        "externalSideEffects": {
          "enum": ["denied", "approval-required"]
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level"],
      "properties": {
        "level": {
          "enum": ["none", "before-write", "before-command", "before-external", "always"]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "completionCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "stopConditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "nextSkills": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z.-]+)?$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)|^[\\\\/]|^[A-Za-z]:"
      }
    },
    "globs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
