{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azi-harness.dev/schemas/manifest.schema.json",
  "title": "AZI Lock Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "harnessVersion",
    "profile",
    "adapters",
    "generatedFiles",
    "seededFiles",
    "initializedAt",
    "syncedAt"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "harnessVersion": {
      "$ref": "#/$defs/semver"
    },
    "profile": {
      "$ref": "#/$defs/component"
    },
    "adapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "generatedFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "source", "generatorVersion"],
        "properties": {
          "path": {
            "$ref": "#/$defs/relativePath"
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "generatorVersion": {
            "$ref": "#/$defs/semver"
          }
        }
      }
    },
    "seededFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "baseSha256", "source"],
        "properties": {
          "path": {
            "$ref": "#/$defs/relativePath"
          },
          "baseSha256": {
            "$ref": "#/$defs/sha256"
          },
          "source": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "initializedAt": {
      "type": "string",
      "format": "date-time"
    },
    "syncedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)|^[\\\\/]|^[A-Za-z]:"
      }
    }
  }
}
