{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azi-harness.dev/schemas/project-config.schema.json",
  "title": "AZI Project Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profile", "adapters", "project"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "$ref": "#/$defs/id"
        },
        "versionRange": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "$ref": "#/$defs/id"
          },
          "options": {
            "type": "object"
          }
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agentDocsRoot", "workItemsRoot"],
      "properties": {
        "agentDocsRoot": {
          "$ref": "#/$defs/relativePath"
        },
        "workItemsRoot": {
          "$ref": "#/$defs/relativePath"
        },
        "rules": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "root"],
            "properties": {
              "name": {
                "$ref": "#/$defs/id"
              },
              "root": {
                "$ref": "#/$defs/relativePath"
              },
              "agentDocs": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "$ref": "#/$defs/relativePath"
                }
              }
            }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disabled": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "skillOverlays": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["skill", "instructions"],
            "properties": {
              "skill": {
                "$ref": "#/$defs/id"
              },
              "instructions": {
                "$ref": "#/$defs/relativePath"
              }
            }
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "telemetry": {
          "const": false
        },
        "allowRemoteProfiles": {
          "const": false
        },
        "generatedFilesInGit": {
          "type": "boolean"
        },
        "executionMode": {
          "enum": ["hitl", "bounded", "afk"]
        },
        "autonomyBudget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxIterations": {
              "type": "integer",
              "minimum": 1
            },
            "maxCommandSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "maxConsecutiveFailures": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)|^[\\\\/]|^[A-Za-z]:"
      }
    }
  }
}
