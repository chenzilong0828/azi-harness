{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://azi-harness.dev/schemas/profile.schema.json",
  "title": "AZI Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "version",
    "description",
    "coreCompatibility",
    "entrySkill",
    "skills",
    "artifacts",
    "seeds",
    "adapterRequirements"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "$ref": "#/$defs/id"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "coreCompatibility": {
      "type": "string",
      "minLength": 1
    },
    "entrySkill": {
      "$ref": "#/$defs/id"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "source"],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "version": {
            "$ref": "#/$defs/semver"
          },
          "source": {
            "$ref": "#/$defs/relativePath"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "format"],
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "format": {
            "enum": ["markdown", "json", "source-change"]
          },
          "defaultPathTemplate": {
            "type": "string",
            "minLength": 1
          },
          "validator": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "ownership", "merge"],
        "properties": {
          "source": {
            "$ref": "#/$defs/relativePath"
          },
          "target": {
            "$ref": "#/$defs/relativePath"
          },
          "ownership": {
            "const": "project"
          },
          "merge": {
            "enum": ["create-only", "suggest-diff"]
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relativePath"
      }
    },
    "adapterRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredCapabilities", "recommendedAdapters"],
      "properties": {
        "requiredCapabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "projectInstructions",
              "skills",
              "namedInvocation",
              "rules",
              "mcp",
              "uiMetadata",
              "projectDiscovery"
            ]
          }
        },
        "recommendedAdapters": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "validators": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z.-]+)?$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^|[\\\\/])\\.\\.([\\\\/]|$)|^[\\\\/]|^[A-Za-z]:"
      }
    }
  }
}
