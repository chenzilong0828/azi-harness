{
  "name": "azi-harness",
  "version": "0.1.2",
  "description": "Team-level AI coding runtime for frontend projects.",
  "type": "module",
  "bin": {
    "azi": "dist/azi.js"
  },
  "files": [
    "dist/azi.js"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "pack:check": "node scripts/pack-check.mjs",
    "bundle": "npx esbuild packages/cli/src/bin.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/azi.js \"--external:node:*\" --external:yaml",
    "prepublishOnly": "npm run bundle",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "azi": "node packages/cli/dist/bin.js"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
